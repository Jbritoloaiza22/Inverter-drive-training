# Ignora objetos y binarios
*.o
*.d
*.elf
*.bin
*.hex
*.map
*.log
*.tmp

# Ignora carpetas de build por defecto
Debug/
Release/

# Excepciones: deja pasar los archivos de build
!STM32CubeIDE/Debug/makefile
!STM32CubeIDE/Debug/*.mk
!STM32CubeIDE/Debug/*.list
!STM32CubeIDE/Debug/src/
!STM32CubeIDE/Debug/Drivers/
!STM32CubeIDE/Release/makefile
!STM32CubeIDE/Release/*.mk
!STM32CubeIDE/Release/*.list
!STM32CubeIDE/Release/src/
!STM32CubeIDE/Release/Drivers/

